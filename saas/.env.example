# =============================================================================
# FluidCalendar SaaS Environment Variables
# =============================================================================
# These variables are required IN ADDITION to the core .env variables
# when running with NEXT_PUBLIC_ENABLE_SAAS_FEATURES=true
# =============================================================================

# -----------------------------------------------------------------------------
# Stripe (Payment Processing)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
STRIPE_PRICE_LIFETIME=price_...

# Stripe Product IDs
STRIPE_PRODUCT_MONTHLY=prod_...
STRIPE_PRODUCT_YEARLY=prod_...
STRIPE_PRODUCT_LIFETIME=prod_...

# -----------------------------------------------------------------------------
# Redis (Background Jobs)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Email Service (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Azure OpenAI (Article Generation / pSEO)
# -----------------------------------------------------------------------------
AZURE_RESOURCE_NAME=your-azure-resource
AZURE_API_KEY=your-api-key
AZURE_DEPLOYMENT_NAME=gpt-4o
AZURE_SEO_DEPLOYMENT_NAME=gpt-4o-mini

# -----------------------------------------------------------------------------
# Admin & Security
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@yourdomain.com
CRON_SECRET=your-cron-secret-for-scheduled-jobs
STATS_API_KEY=your-stats-api-key

# -----------------------------------------------------------------------------
# Deployment (for CI/CD workflows)
# -----------------------------------------------------------------------------
# These are typically set as GitHub Secrets, not in .env
# CONTAINER_REGISTRY=registry.digitalocean.com/your-namespace
# K8S_CLUSTER_NAME=your-cluster
# INFISICAL_API_URL=https://your-infisical-instance
# INFISICAL_PROJECT_ID=your-project-id
# INFISICAL_TOKEN=your-token
# DIGITALOCEAN_ACCESS_TOKEN=your-token
